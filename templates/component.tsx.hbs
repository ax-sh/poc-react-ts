import { useQuery } from '@tanstack/react-query'
import axios from 'axios'

function use{{pascalCase name}}Data() {
    async function queryFn() {
        const x = await axios.get<{ health: string }>('/health')
        return x.data
    }
    return useQuery({ queryKey: ['data'], queryFn })
}


export default function {{pascalCase name}}(){
    const { data, isLoading, isError } = use{{pascalCase name}}Data()
    if(isLoading) return <h1>Loading</h1>
    if(isError) return <h1>Error</h1>

    return <section className="{{camelCase name}} bg-red-500">
        <h1>{{pascalCase name}}</h1>
        <pre>{JSON.stringify(data, null,2)}</pre>
    </section>
}